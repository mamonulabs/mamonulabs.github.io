---
interface Props { src: string; title: string; }
const { src, title } = Astro.props;
const id = `player-${Math.random().toString(36).slice(2, 9)}`;
---
<div class="my-4 border border-white/10 bg-white/[0.02]" data-waveplayer data-src={src} id={id}>
  <div class="flex items-center gap-4 px-4 py-3">
    <button class="flex-shrink-0 w-10 h-10 flex items-center justify-center border border-white/20 text-white hover:bg-primary hover:border-primary transition-all" data-play-btn aria-label="Play">
      <span class="material-symbols-outlined text-[18px] play-icon">play_arrow</span>
      <span class="material-symbols-outlined text-[18px] pause-icon hidden">pause</span>
    </button>
    <div class="flex-1 min-w-0">
      <div class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2 truncate">{title}</div>
      <div data-waveform class="w-full"></div>
    </div>
    <span class="text-xs text-slate-500 font-mono tabular-nums flex-shrink-0" data-time>0:00</span>
  </div>
</div>
