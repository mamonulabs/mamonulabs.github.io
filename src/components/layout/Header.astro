---
const navItems = [
  { label: 'All Plugins', href: '/plugins' },
  { label: 'Downloads', href: '/downloads' },
  { label: 'InfoBits', href: '/infobits' },
  { label: 'Blog', href: '/blog' },
];
---
<header class="flex items-center justify-between px-6 py-6 md:px-12 grid-border-b bg-background-dark/80 backdrop-blur-md sticky top-0 z-50">
  <div class="flex items-center gap-2">
    <a href="/" class="text-2xl font-bold tracking-tighter lowercase hover:text-primary transition-colors">mamonulabs</a>
  </div>
  <nav class="hidden md:flex items-center gap-10">
    {navItems.map((item) => (
      <a href={item.href} class="text-sm font-medium hover:text-primary transition-colors uppercase tracking-widest">
        {item.label}
      </a>
    ))}
  </nav>
  <div class="flex items-center gap-4">
    <a href="/support" class="flex items-center justify-center p-2 hover:bg-white/10 transition-colors" aria-label="Support">
      <span class="material-symbols-outlined text-[20px]">chat</span>
    </a>
    <button class="md:hidden flex items-center justify-center p-2 hover:bg-white/10 transition-colors" aria-label="Open menu">
      <span class="material-symbols-outlined text-[20px]">menu</span>
    </button>
  </div>
</header>
