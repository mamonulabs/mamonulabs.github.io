---
const currentYear = new Date().getFullYear();
const footerSections = [
  { title: 'Products', links: [
    { label: 'All Plugins', href: '/plugins' },
    { label: 'Downloads', href: '/downloads' },
    { label: 'Gumroad', href: 'https://mamonulabs.gumroad.com' },
  ]},
  { title: 'Learn', links: [
    { label: 'InfoBits', href: '/infobits' },
    { label: 'Blog', href: '/blog' },
  ]},
  { title: 'Connect', links: [
    { label: 'GitHub', href: 'https://github.com/mamonulabs' },
  ]},
];
---
<footer class="bg-background-dark px-6 md:px-12 py-16">
  <div class="max-w-[1400px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <div class="flex flex-col gap-6">
        <span class="text-2xl font-bold tracking-tighter lowercase">mamonulabs</span>
        <p class="text-slate-500 text-sm max-w-xs leading-relaxed">
          Crafting advanced audio tools for those who explore the boundaries of sound design and music theory.
        </p>
      </div>
      {footerSections.map((section) => (
        <div class="flex flex-col gap-6">
          <span class="text-xs font-bold uppercase tracking-widest text-primary">{section.title}</span>
          <nav class="flex flex-col gap-3">
            {section.links.map((link) => (
              <a href={link.href} class="text-sm uppercase tracking-wider hover:text-primary transition-colors">{link.label}</a>
            ))}
          </nav>
        </div>
      ))}
    </div>
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[10px] text-slate-600 uppercase tracking-[0.2em]">&copy; {currentYear} mamonulabs. All rights reserved.</p>
      <div class="flex gap-8">
        <a href="/faq" class="text-[10px] text-slate-600 uppercase tracking-[0.2em] hover:text-white transition-colors">FAQ</a>
        <a href="/support" class="text-[10px] text-slate-600 uppercase tracking-[0.2em] hover:text-white transition-colors">Support</a>
      </div>
    </div>
  </div>
</footer>
