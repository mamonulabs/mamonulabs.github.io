---
interface Props {
  name: string;
  tagline: string;
  slug: string;
  image?: string;
}
const { name, tagline, slug, image } = Astro.props;
---
<a href={`/plugins/${slug}`} class="group cursor-pointer relative overflow-hidden grid-border">
  {image && (
    <div class="aspect-square w-full grayscale group-hover:grayscale-0 transition-all duration-700 overflow-hidden">
      <img src={image} alt={name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
    </div>
  )}
  <div class="p-6 md:p-8 bg-background-dark border-t border-white/10">
    <h3 class="text-xl font-bold uppercase mb-2">{name}</h3>
    <p class="text-sm text-slate-400 uppercase tracking-wider">{tagline}</p>
  </div>
</a>
