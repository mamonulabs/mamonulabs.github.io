---
interface Props {
  title: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}
const { title, subtitle, primaryCta, secondaryCta } = Astro.props;
---
<section class="px-6 md:px-12 py-20 md:py-32 grid-border-b">
  <div class="max-w-[1400px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
      <div class="lg:col-span-8">
        <h1 class="text-6xl md:text-8xl font-bold leading-[0.85] tracking-tighter uppercase mb-8 lg:text-[9rem]" set:html={title} />
      </div>
      <div class="lg:col-span-4 pb-4">
        {subtitle && (
          <p class="text-lg md:text-xl text-slate-400 font-light mb-8 max-w-md leading-relaxed">
            {subtitle}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-4">
          {primaryCta && (
            <a href={primaryCta.href} class="group flex items-center gap-4 bg-primary px-8 py-4 text-white font-bold uppercase tracking-widest hover:bg-white hover:text-black transition-all">
              <span>{primaryCta.label}</span>
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class="flex items-center gap-4 px-8 py-4 text-slate-400 font-bold uppercase tracking-widest hover:text-white border border-white/10 hover:border-white/30 transition-all">
              <span>{secondaryCta.label}</span>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
