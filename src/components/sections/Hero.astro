---
interface Props {
  title: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}
const { title, subtitle, primaryCta, secondaryCta } = Astro.props;
---
<section class="min-h-[80vh] flex items-center py-32">
  <div class="max-w-6xl mx-auto px-6">
    <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-synth-cyan glow-cyan leading-tight">
      {title}
    </h1>
    {subtitle && <p class="mt-6 text-xl text-dark-100 leading-relaxed max-w-2xl">{subtitle}</p>}
    <div class="mt-8 flex flex-wrap gap-4">
      {primaryCta && (
        <a href={primaryCta.href} class="px-6 py-3 bg-synth-pink text-white font-semibold rounded-lg hover:bg-synth-pink-light transition-all duration-300 box-glow-pink">
          {primaryCta.label}
        </a>
      )}
      {secondaryCta && (
        <a href={secondaryCta.href} class="px-6 py-3 glass border-2 border-forest-500 text-forest-400 font-semibold rounded-lg hover:box-glow-forest transition-all duration-300">
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
