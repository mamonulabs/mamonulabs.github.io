---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import PluginCard from '../../components/ui/PluginCard.astro';
import { getCollection } from 'astro:content';

const plugins = await getCollection('plugins', ({ data }) => data.published !== false);
const sorted = plugins.sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Plugins">
  <Header />
  <main class="flex-grow">
    <section class="px-6 md:px-12 py-20 md:py-32 grid-border-b">
      <div class="max-w-[1400px] mx-auto">
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary mb-8 block">Catalog</span>
        <h1 class="text-6xl md:text-8xl font-bold tracking-tighter uppercase mb-4">Plugins</h1>
        <p class="text-xl text-slate-400 font-light max-w-xl">Audio effects for creative music production</p>
      </div>
    </section>
    <section class="grid-border-b">
      <div class="grid md:grid-cols-2">
        {sorted.map((plugin) => (
          <PluginCard name={plugin.data.name} tagline={plugin.data.tagline} slug={plugin.slug} image={plugin.data.image} />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
