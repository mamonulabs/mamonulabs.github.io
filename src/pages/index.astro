---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import PluginCard from '../components/ui/PluginCard.astro';
import { getCollection } from 'astro:content';

const plugins = await getCollection('plugins', ({ data }) => data.published !== false);
const sortedPlugins = plugins.sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Audio Plugins for Creative Music Production">
  <Header />
  <main class="flex-grow">
    <Hero
      title="plugins <br/> that inspire <br/> creativity"
      subtitle="Probability-based effects and unique sound design tools for adventurous music producers."
      primaryCta={{ label: "Explore Plugins", href: "/plugins" }}
      secondaryCta={{ label: "Learn More", href: "/about" }}
    />

    <section class="grid-border-b">
      <div class="p-6 md:p-12 grid-border-b flex flex-col justify-between min-h-[200px]">
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary">01 / Featured</span>
        <h2 class="text-3xl font-bold uppercase mt-8">Selected works for the modern studio.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2">
        {sortedPlugins.map((plugin) => (
          <PluginCard
            name={plugin.data.name}
            tagline={plugin.data.tagline}
            slug={plugin.slug}
            image={plugin.data.image}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
