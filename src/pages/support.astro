---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---
<BaseLayout title="Support" description="Get support for mamonulabs plugins">
  <Header />
  <main class="flex-grow">
    <section class="px-6 md:px-12 py-20 md:py-32 grid-border-b">
      <div class="max-w-[1400px] mx-auto">
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary mb-8 block">Support</span>
        <h1 class="text-6xl md:text-8xl font-bold tracking-tighter uppercase mb-8">Support</h1>
        <p class="text-xl text-slate-400 font-light max-w-xl mb-8">Need help? Reach out through our community channels.</p>
        <a href="https://github.com/mamonulabs/mamonulabs.github.io/issues" class="group inline-flex items-center gap-4 bg-primary px-8 py-4 text-white font-bold uppercase tracking-widest hover:bg-white hover:text-black transition-all">
          <span>Open an Issue</span>
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
