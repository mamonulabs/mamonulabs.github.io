---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const faqs = [
  {
    question: "What platforms are supported?",
    answer: "Our plugins are available as VST3, AU, and CLAP formats for macOS and Windows."
  },
  {
    question: "Are the plugins free?",
    answer: "Information about pricing and availability will be announced soon."
  },
  {
    question: "How do I install the plugins?",
    answer: "Installation instructions will be provided with each plugin download."
  }
];
---
<BaseLayout title="FAQ" description="Frequently asked questions about mamonulabs plugins">
  <Header />
  <main class="flex-grow">
    <section class="px-6 md:px-12 py-20 md:py-32 grid-border-b">
      <div class="max-w-[1400px] mx-auto">
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary mb-8 block">FAQ</span>
        <h1 class="text-6xl md:text-8xl font-bold tracking-tighter uppercase">Frequently Asked Questions</h1>
      </div>
    </section>
    <section class="grid-border-b">
      <div class="max-w-[1400px] mx-auto">
        {faqs.map((faq, i) => (
          <div class={`px-6 md:px-12 py-10 ${i < faqs.length - 1 ? 'grid-border-b' : ''}`}>
            <span class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4 block">{String(i + 1).padStart(2, '0')}</span>
            <h2 class="text-2xl font-bold uppercase mb-4">{faq.question}</h2>
            <p class="text-slate-400 leading-relaxed max-w-2xl">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
