---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---
<BaseLayout title="About ForestWare" description="About ForestWare and the person behind it">
  <Header />
  <main class="pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="font-display text-5xl md:text-6xl font-bold text-synth-cyan glow-cyan mb-8 text-center">About ForestWare</h1>
      <div class="flex justify-center mb-12">
        <div class="glass-strong p-8 rounded-2xl">
          <img src="/assets/img/FPsy.png" alt="ForestPsyWare Logo" class="max-w-md w-full h-auto rounded-xl" />
        </div>
      </div>
      <div class="glass-strong p-8 rounded-2xl text-center">
        <p class="text-xl text-dark-100 mb-8">Audio plugins and tools for creative music production.</p>
        <p class="text-2xl text-forest-400 glow-forest">🎶🌲ForestWare🌲🎶</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
