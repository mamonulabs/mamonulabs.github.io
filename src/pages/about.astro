---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---
<BaseLayout title="About mamonulabs" description="About mamonulabs and the person behind it">
  <Header />
  <main class="flex-grow">
    <section class="px-6 md:px-12 py-20 md:py-32 grid-border-b">
      <div class="max-w-[1400px] mx-auto">
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary mb-8 block">About</span>
        <h1 class="text-6xl md:text-8xl font-bold tracking-tighter uppercase mb-8">mamonulabs</h1>
        <p class="text-xl text-slate-400 font-light max-w-xl">Audio plugins and tools for creative music production.</p>
      </div>
    </section>
    <section class="px-6 md:px-12 py-20 grid-border-b">
      <div class="max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="overflow-hidden">
          <img src="/assets/img/FPsy.png" alt="ForestPsyWare Logo" class="w-full h-auto" />
        </div>
        <div>
          <p class="text-lg text-slate-300 leading-relaxed mb-6">
            Crafting advanced audio tools for those who explore the boundaries of sound design and music theory.
          </p>
          <p class="text-2xl font-bold uppercase tracking-wider">🎶🌲mamonulabs🌲🎶</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
