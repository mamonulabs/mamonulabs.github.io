---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---
<BaseLayout title="Downloads" description="Download mamonulabs audio plugins">
  <Header />
  <main class="flex-grow">
    <section class="px-6 md:px-12 py-20 md:py-32 grid-border-b">
      <div class="max-w-[1400px] mx-auto">
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary mb-8 block">Downloads</span>
        <h1 class="text-6xl md:text-8xl font-bold tracking-tighter uppercase mb-8">Downloads</h1>
        <p class="text-xl text-slate-400 font-light max-w-xl">Plugin downloads coming soon.</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
