---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---
<BaseLayout title="Downloads" description="Download ForestWare audio plugins">
  <Header />
  <main class="pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="font-display text-5xl md:text-6xl font-bold text-neutral-900 mb-8 text-center">Downloads</h1>
      <div class="prose prose-neutral prose-lg max-w-none">
        <p class="text-xl text-neutral-600 text-center mb-8">Plugin downloads coming soon.</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
