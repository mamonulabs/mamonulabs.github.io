---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const infobits = await getCollection('infobits');
---
<BaseLayout title="InfoBits">
  <Header />
  <main class="pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <h1 class="font-display text-5xl md:text-6xl font-bold text-synth-purple glow-pink text-center mb-4">InfoBits</h1>
      <p class="text-xl text-dark-100 text-center mb-16">Quick insights into synthesizer modules and gear</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {infobits.map((infobit) => (
          <a href={`/infobits/${infobit.slug}`} class="group block glass rounded-2xl overflow-hidden hover:glass-strong hover:box-glow-pink transition-all duration-300 p-6">
            <h3 class="font-display text-2xl font-bold text-synth-pink group-hover:glow-pink transition-all duration-300">{infobit.data.title}</h3>
            <p class="mt-2 text-dark-100">{infobit.data.description}</p>
            <span class="mt-4 inline-block text-forest-400 font-medium">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
