---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const infobits = await getCollection('infobits');

const infobitsWithMeta = infobits.map(infobit => ({
  ...infobit,
  readingTime: infobit.data.readingTime || Math.ceil(infobit.body.split(/\s+/).length / 200)
}));
---
<BaseLayout title="InfoBits">
  <Header />
  <main class="flex-grow">
    <section class="px-6 md:px-12 py-20 md:py-32 grid-border-b">
      <div class="max-w-[1400px] mx-auto">
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary mb-8 block">Knowledge Base</span>
        <h1 class="text-6xl md:text-8xl font-bold tracking-tighter uppercase mb-4">InfoBits</h1>
        <p class="text-xl text-slate-400 font-light max-w-xl">Deep dives into synthesizer modules, music technology, and gear history</p>
      </div>
    </section>

    <section class="grid-border-b">
      <div class="grid md:grid-cols-2 lg:grid-cols-3">
        {infobitsWithMeta.map((infobit) => (
          <a
            href={`/infobits/${infobit.slug}`}
            class="group p-6 md:p-8 grid-border hover:bg-white/5 transition-all duration-300"
          >
            <h3 class="text-xl font-bold uppercase mb-3 group-hover:text-primary transition-colors">
              {infobit.data.title}
            </h3>
            <p class="text-slate-400 mb-4 line-clamp-3">
              {infobit.data.description}
            </p>
            <div class="flex items-center justify-between pt-4 border-t border-white/10">
              <span class="text-xs text-slate-500 uppercase tracking-widest">
                {infobit.readingTime} min read
              </span>
              <span class="text-primary font-medium flex items-center gap-1 group-hover:gap-2 transition-all text-sm uppercase tracking-wider">
                Read
                <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
