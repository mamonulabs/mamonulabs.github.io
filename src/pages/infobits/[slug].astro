---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const infobits = await getCollection('infobits');
  return infobits.map((infobit) => ({ params: { slug: infobit.slug } }));
}

const { slug } = Astro.params;
const infobit = await getEntry('infobits', slug);
const { Content } = await infobit.render();

// Calculate reading time from content
const wordCount = infobit.body.split(/\s+/).length;
const readingTime = infobit.data.readingTime || Math.ceil(wordCount / 200);
---
<BaseLayout title={infobit.data.title} description={infobit.data.description}>
  <Header />
  <main class="pt-24 pb-20">
    <article class="max-w-3xl mx-auto px-6">
      <!-- Category Badge -->
      <div class="text-center mb-8">
        <span class="inline-block px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-synth-cyan border border-synth-cyan/30 rounded-full">
          InfoBit
        </span>
      </div>

      <!-- Title -->
      <h1 class="font-display text-4xl md:text-5xl font-bold text-center text-synth-pink leading-tight mb-6">
        {infobit.data.title}
      </h1>

      <!-- Description/Subtitle -->
      <p class="text-xl text-dark-100 text-center max-w-2xl mx-auto leading-relaxed mb-8">
        {infobit.data.description}
      </p>

      <!-- Meta Info -->
      <div class="flex items-center justify-center gap-6 text-sm text-dark-200 mb-10">
        {infobit.data.author && (
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            {infobit.data.author}
          </span>
        )}
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {readingTime} min read
        </span>
      </div>

      <!-- Decorative Divider -->
      <div class="flex items-center justify-center gap-4 mb-12">
        <div class="h-px w-16 bg-gradient-to-r from-transparent to-synth-purple/50"></div>
        <div class="w-2 h-2 rotate-45 bg-synth-purple"></div>
        <div class="h-px w-16 bg-gradient-to-l from-transparent to-synth-purple/50"></div>
      </div>

      <!-- Article Content -->
      <div class="article-content">
        <Content />
      </div>

      <!-- End Decoration -->
      <div class="flex items-center justify-center gap-4 mt-16 mb-12">
        <div class="h-px w-24 bg-gradient-to-r from-transparent to-synth-purple/50"></div>
        <span class="text-synth-purple text-2xl">&#10022;</span>
        <div class="h-px w-24 bg-gradient-to-l from-transparent to-synth-purple/50"></div>
      </div>

      <!-- Back Link -->
      <div class="text-center">
        <a
          href="/infobits"
          class="inline-flex items-center gap-2 text-forest-400 hover:text-forest-300 font-medium transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back to all InfoBits
        </a>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .article-content {
    color: #e8e0f0;
    font-size: 1.125rem;
    line-height: 1.9;
  }

  /* Paragraphs - generous spacing */
  .article-content p {
    margin-bottom: 1.75rem;
    text-align: left;
  }

  /* First paragraph after heading gets a drop cap */
  .article-content h2:first-of-type + p::first-letter {
    float: left;
    font-family: 'Fraunces', serif;
    font-size: 4rem;
    line-height: 0.8;
    padding-right: 0.75rem;
    padding-top: 0.25rem;
    color: #05d9e8;
    font-weight: 600;
  }

  /* Headings */
  .article-content h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: #05d9e8;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(5, 217, 232, 0.2);
  }

  .article-content h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.375rem;
    font-weight: 600;
    color: #4ade80;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  /* Links */
  .article-content a {
    color: #ff2a6d;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 42, 109, 0.3);
    transition: border-color 0.2s;
  }

  .article-content a:hover {
    border-bottom-color: #ff2a6d;
  }

  /* Bold text */
  .article-content strong {
    color: #4ade80;
    font-weight: 600;
  }

  /* Italic text */
  .article-content em {
    color: #f0e6ff;
    font-style: italic;
  }

  /* Images - contained and styled */
  .article-content img {
    display: block;
    max-width: 80%;
    height: auto;
    margin: 2.5rem auto;
    border-radius: 0.75rem;
    border: 1px solid rgba(74, 66, 96, 0.4);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  /* Blockquotes - pull quote style */
  .article-content blockquote {
    margin: 2.5rem 0;
    padding: 1.5rem 2rem;
    background: rgba(138, 43, 226, 0.1);
    border-left: 4px solid #8b5cf6;
    border-radius: 0 0.75rem 0.75rem 0;
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    font-style: italic;
    color: #f0e6ff;
  }

  .article-content blockquote p {
    margin-bottom: 0;
  }

  /* Horizontal rules */
  .article-content hr {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(138, 43, 226, 0.5), transparent);
    margin: 3rem 0;
  }

  /* Lists */
  .article-content ul,
  .article-content ol {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .article-content li {
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
  }

  .article-content ul li::marker {
    color: #05d9e8;
  }

  .article-content ol li::marker {
    color: #05d9e8;
    font-weight: 600;
  }

  /* Code */
  .article-content code {
    font-family: ui-monospace, monospace;
    font-size: 0.9em;
    color: #ff2a6d;
    background: rgba(26, 20, 40, 0.6);
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
  }

  /* Preformatted blocks */
  .article-content pre {
    margin: 2rem 0;
    padding: 1.5rem;
    background: rgba(26, 20, 40, 0.8);
    border-radius: 0.75rem;
    border: 1px solid rgba(74, 66, 96, 0.3);
    overflow-x: auto;
  }

  .article-content pre code {
    background: none;
    padding: 0;
    color: #e8e0f0;
  }
</style>
