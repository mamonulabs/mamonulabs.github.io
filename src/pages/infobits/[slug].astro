---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const infobits = await getCollection('infobits');
  return infobits.map((infobit) => ({ params: { slug: infobit.slug } }));
}

const { slug } = Astro.params;
const infobit = await getEntry('infobits', slug);
const { Content } = await infobit.render();

const wordCount = infobit.body.split(/\s+/).length;
const readingTime = infobit.data.readingTime || Math.ceil(wordCount / 200);
---
<BaseLayout title={infobit.data.title} description={infobit.data.description}>
  <Header />
  <main class="flex-grow">
    <section class="px-6 md:px-12 py-20 md:py-32 grid-border-b">
      <div class="max-w-[1400px] mx-auto">
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary mb-8 block">InfoBit</span>
        <h1 class="text-5xl md:text-7xl font-bold tracking-tighter uppercase leading-tight mb-6">
          {infobit.data.title}
        </h1>
        <p class="text-xl text-slate-400 font-light max-w-2xl mb-6">
          {infobit.data.description}
        </p>
        <div class="flex items-center gap-6 text-sm text-slate-500 uppercase tracking-widest">
          {infobit.data.author && (
            <span>{infobit.data.author}</span>
          )}
          <span>{readingTime} min read</span>
        </div>
      </div>
    </section>

    <article class="px-6 md:px-12 py-16 grid-border-b">
      <div class="max-w-3xl mx-auto article-content">
        <Content />
      </div>
    </article>

    <section class="px-6 md:px-12 py-10">
      <div class="max-w-[1400px] mx-auto">
        <a
          href="/infobits"
          class="group inline-flex items-center gap-2 text-primary hover:text-white font-bold uppercase tracking-widest transition-colors"
        >
          <span class="material-symbols-outlined group-hover:-translate-x-1 transition-transform">arrow_back</span>
          Back to all InfoBits
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .article-content {
    color: #cbd5e1;
    font-size: 1.125rem;
    line-height: 1.9;
  }

  .article-content p {
    margin-bottom: 1.75rem;
    text-align: left;
  }

  .article-content h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.025em;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .article-content h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.375rem;
    font-weight: 700;
    color: #0d59f2;
    text-transform: uppercase;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .article-content a {
    color: #0d59f2;
    text-decoration: none;
    border-bottom: 1px solid rgba(13, 89, 242, 0.3);
    transition: border-color 0.2s, color 0.2s;
  }

  .article-content a:hover {
    color: #fff;
    border-bottom-color: #fff;
  }

  .article-content strong {
    color: #fff;
    font-weight: 600;
  }

  .article-content em {
    color: #e2e8f0;
    font-style: italic;
  }

  .article-content img {
    display: block;
    max-width: 80%;
    height: auto;
    margin: 2.5rem auto;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .article-content blockquote {
    margin: 2.5rem 0;
    padding: 1.5rem 2rem;
    background: rgba(13, 89, 242, 0.1);
    border-left: 4px solid #0d59f2;
    font-size: 1.25rem;
    font-style: italic;
    color: #e2e8f0;
  }

  .article-content blockquote p {
    margin-bottom: 0;
  }

  .article-content hr {
    border: none;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 3rem 0;
  }

  .article-content ul,
  .article-content ol {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .article-content li {
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
  }

  .article-content ul li::marker {
    color: #0d59f2;
  }

  .article-content ol li::marker {
    color: #0d59f2;
    font-weight: 600;
  }

  .article-content code {
    font-family: ui-monospace, monospace;
    font-size: 0.9em;
    color: #e2e8f0;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.2em 0.4em;
  }

  .article-content pre {
    margin: 2rem 0;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    overflow-x: auto;
  }

  .article-content pre code {
    background: none;
    padding: 0;
    color: #e2e8f0;
  }
</style>
